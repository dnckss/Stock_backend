# Quantix stock_ai 백엔드 — 환경변수 템플릿.
# 이 파일을 `.env` 로 복사 후 실제 값으로 채우세요. .env 는 .gitignore 에 등록되어 있습니다.

# ---------- 필수 (없으면 부팅 실패) ----------
# Supabase Project Settings → API 에서 복사
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# ---------- 권장 (없으면 LLM 기능 비활성) ----------
OPENAI_API_KEY=sk-...

# ---------- 선택 ----------
# 로컬/CI 에서 부팅 fail-fast 를 끄고 싶을 때
# STRICT_ENV=false

# CORS — env 미설정 시 "*"(개발 모드). 운영은 도메인 화이트리스트 권장.
# CORS_ALLOW_ORIGINS=https://app.example.com,https://staging.example.com

# OpenAI 모델 오버라이드
# OPENAI_MODEL=gpt-5
# STRATEGIST_OPENAI_MODEL=gpt-5
# STRATEGIST_REASONING_EFFORT=medium
# FINBERT_OPENAI_MODEL=gpt-4o-mini

# 서버 포트 (PaaS 가 주입하지 않을 때만)
# PORT=8000

# 백그라운드 루프 자동 복구 임계
# LOOP_BACKOFF_MAX_SEC=1800
# LOOP_FAILURE_ALERT_THRESHOLD=5

# 스캔 안정성 / 가격 갱신 (yfinance 차단 위험 vs 신선도 트레이드오프)
# MIN_TOP_PICKS_FRESH=250        # 이 개수 미만 사이클은 stale 처리 (직전 스냅샷 유지)
# PRICE_TICK_INTERVAL_SEC=30     # 분봉 시세 갱신 주기 (초)
# PRICE_TICK_MAX_SYMBOLS=250     # 한 사이클에 갱신할 종목 상한

# WebSocket 운영
# WS_MAX_CONNECTIONS=200
# WS_HEARTBEAT_INTERVAL_SEC=30
# WS_IDLE_TIMEOUT_SEC=300

# 섹터 트래커 캐시 / 임계
# SECTOR_TRACKER_CACHE_TTL_SEC=600
# SECTOR_TRACKER_STRONG_MOVE_PCT=0.02
# SECTOR_TRACKER_NORMAL_MOVE_PCT=0.005
# SECTOR_TRACKER_ROTATION_MIN_EDGE_PCT=0.005

# 추천 진입가 환각 보정 (strategist)
# STRATEGIST_ENTRY_DEVIATION_THRESHOLD=0.15
# STRATEGIST_ENTRY_NORMALIZED_BAND_PCT=0.005
# STRATEGIST_NORMALIZED_STOP_LOSS_PCT=0.03
